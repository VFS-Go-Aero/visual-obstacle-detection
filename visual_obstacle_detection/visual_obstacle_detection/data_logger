#  Main
# ══════════════════════════════════════════════════════════
def handle_signal(sig, frame):
    print("\n[INFO] Stopping — flushing all logs ...")
    stop_event.set()


def main():
    parser = argparse.ArgumentParser(description="Drone comprehensive data logger")
    parser.add_argument("--connection", default=MAV_CONNECTION)
    parser.add_argument("--log-dir",   default=LOG_DIR)
    parser.add_argument("--no-ros2",   action="store_true")
    parser.add_argument("--no-system", action="store_true")
    parser.add_argument("--no-health", action="store_true")
    args = parser.parse_args()

    session = session_dir(args.log_dir)
    print(f"\n{'='*55}")
    print(f"  Drone Data Logger — session: {session.name}")
    print(f"  Logs → {session}")
    print(f"{'='*55}\n")

    # Write session metadata
    with open(session / "session_info.txt", "w") as f:
        f.write(f"Start       : {ts()}\n")
        f.write(f"MAVLink     : {args.connection}\n")
        f.write(f"ROS distro  : {ROS_DISTRO}\n")
        f.write(f"Log rate    : {LOG_HZ} Hz\n")

    signal.signal(signal.SIGINT,  handle_signal)
    signal.signal(signal.SIGTERM, handle_signal)

    threads = []

    # MAVLink (always on)
    mav_logger = MAVLinkLogger(session)
    mav_logger.start()
    threads.append(mav_logger)

    # ROS2
    if not args.no_ros2:
        ros_logger = ROS2Logger(session)
        ros_logger.start()
        threads.append(ros_logger)
        print("[ROS2]    Topic logger started.")

    # System journal
    if not args.no_system:
        sys_logger = SystemLogger(session)
        sys_logger.start()
        threads.append(sys_logger)
        print("[System]  Journal logger started.")

    # Jetson health
    if not args.no_health:
        health_logger = JetsonHealthLogger(session)
        health_logger.start()
        threads.append(health_logger)
        print("[Health]  Jetson health CSV logger started.")

    print("\n[INFO] All loggers running. Press Ctrl+C to stop.\n")
    stop_event.wait()

    for t in threads:
        t.join(timeout=4)

    with open(session / "session_info.txt", "a") as f:
        f.write(f"End         : {ts()}\n")

    print(f"\n[DONE] All logs saved to: {session}\n")

    # Print summary of files created
    print("Files created:")
    for f in sorted(session.iterdir()):
        size = f.stat().st_size
        print(f"  {f.name:<30} {size:>8,} bytes")


if __name__ == "__main__":
    main()
    